#pragma once

#include <iostream>
#include <string>
#include "containers/doubly_linked_list.hpp"

class Genre {
    public:
        enum Value {
            ACTION = 1,
            COMEDY = 2,
            ROMANCE = 3,
            HORROR = 4,
            SUSPENSE = 5,
